<?xml version="1.0"?>
<ruleset name="Custom Theme">
    <description>WordPress Coding Standards for Custom Theme</description>

    <!-- Scan theme tree; dependencies are excluded below -->
    <file>.</file>

    <!-- Only PHP — avoids scanning node_modules JS and keeps runs fast -->
    <arg name="extensions" value="php"/>

    <!-- WordPress PHP standards -->
    <rule ref="WordPress-Core"/>
    <rule ref="WordPress-Extra"/>
    <rule ref="WordPress-Docs"/>

    <!-- Indent: 2 spaces (override WordPress default of tabs) -->
    <arg name="tab-width" value="2"/>
    <rule ref="Generic.WhiteSpace.DisallowSpaceIndent">
        <severity>0</severity>
    </rule>
    <rule ref="Generic.WhiteSpace.ScopeIndent">
        <properties>
            <property name="indent" value="2"/>
            <property name="tabIndent" value="false"/>
        </properties>
    </rule>
    <rule ref="PEAR.Functions.FunctionCallSignature">
        <properties>
            <property name="indent" value="2"/>
        </properties>
    </rule>
    <rule ref="Universal.WhiteSpace.PrecisionAlignment">
        <severity>0</severity>
    </rule>

    <!-- Cyclomatic complexity ≤ 10 -->
    <rule ref="Generic.Metrics.CyclomaticComplexity">
        <properties>
            <property name="complexity" value="10"/>
            <property name="absoluteComplexity" value="20"/>
        </properties>
    </rule>

    <!-- Max nesting depth 3 -->
    <rule ref="Generic.Metrics.NestingLevel">
        <properties>
            <property name="nestingLevel" value="3"/>
            <property name="absoluteNestingLevel" value="5"/>
        </properties>
    </rule>

    <!-- No commented-out code -->
    <rule ref="Squiz.PHP.CommentedOutCode">
        <properties>
            <property name="maxPercentage" value="35"/>
        </properties>
    </rule>

    <!-- No TODO/FIXME comments -->
    <rule ref="Generic.Commenting.Todo"/>
    <rule ref="Generic.Commenting.Fixme"/>

    <!-- Nested paths: plain vendor/* does not exclude vendor/pkg/file.php -->
    <exclude-pattern>*/vendor/*</exclude-pattern>
    <exclude-pattern>*/node_modules/*</exclude-pattern>
    <exclude-pattern>*/build/*</exclude-pattern>
    <exclude-pattern>*/scripts/*</exclude-pattern>

    <!-- CLI -->
    <arg value="p"/>
    <arg name="colors"/>
</ruleset>
